{
	"name": "n8n-nodes-acquibee",
	"version": "0.1.3",
	"description": "n8n community node to interact with the Acquibee Client API",
	"keywords": [
		"n8n-community-node-package"
	],
	"license": "MIT",
	"homepage": "https://github.com/acquibee/n8n-nodes-acquibee#readme",
	"author": {
		"name": "Acquibee",
		"email": "support@acquibee.de"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/acquibee/n8n-nodes-acquibee.git"
	},
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"test": "n8n-node lint && n8n-node build",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/AcquibeeApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Acquibee/Acquibee.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "0.31.0",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
